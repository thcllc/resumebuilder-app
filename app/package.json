{
  "name": "resumebuilderapp",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.26.0",
  "bin": {
    "resume-local": "./cli/resume.mjs"
  },
  "scripts": {
    "dev": "vite",
    "cli": "node cli/resume.mjs",
    "typecheck": "tsc --noEmit",
    "build": "pnpm typecheck && vite build",
    "preview": "vite preview",
    "test:smoke": "playwright test",
    "docker:build": "docker build -t resumebuilderapp .",
    "deploy:pages": "pnpm build && pnpm dlx wrangler@latest pages deploy dist --project-name resumebuilderapp"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "playwright": "^1.59.1",
    "typescript": "^5.7.2"
  }
}
